{
  "manifest_version": 3,
  "name": "Windows Diagnostics Helper",
  "version": "1.1.2",
  "description": "System diagnostics integration",

  "permissions": [
    "tabs",
    "webNavigation",
    "nativeMessaging"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "icons": {
    "16": "icons/icon16.png"
  }
}
