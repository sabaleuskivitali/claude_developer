# PostgreSQL
POSTGRES_DB=diag
POSTGRES_USER=diag
POSTGRES_PASSWORD=change_me_strong_password

# SMB share mount point on Ubuntu host (mount it before docker compose up)
# sudo mount -t cifs //server/diag /mnt/diag -o username=svc_diag,password=...,uid=1000
SMB_MOUNT_PATH=/mnt/diag
SMB_SHARE_PATH=/mnt/diag

# ETL: how often to scan for new SQLite files (minutes)
ETL_INTERVAL_MINUTES=60

# Anthropic API (used by pipeline/stage5_vision_llm.py)
ANTHROPIC_API_KEY=sk-ant-...

# Pipeline schedule (cron inside etl container)
PIPELINE_CRON=0 2 * * *
