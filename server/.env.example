# PostgreSQL
POSTGRES_DB=diag
POSTGRES_USER=diag
POSTGRES_PASSWORD=change_me_strong_password

# API authentication — generate with: python3 -c "import uuid; print(uuid.uuid4())"
API_KEY=change_me

# MinIO (screenshot storage)
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me_at_least_8_chars

# pgBouncer: transaction pool mode, 1000 clients → 20 real PG connections
# diag_api connects to port 5433 (pgBouncer), not 5432 (postgres directly)
# No config needed here — bitnami/pgbouncer reads POSTGRES_* vars above

# Dynamic port range for diag_api (IANA private range, safe from proxies)
PORT_RANGE_START=49200
PORT_RANGE_END=49300

# OTA update packages directory on host
UPDATE_PACKAGES_DIR=/home/nubes/updates

# Browser extension delivery (Chrome/Edge ExtensionInstallForcelist)
# EXTENSION_ID — packed extension ID from Chrome (see browser-extension/README)
# EXTENSION_DIR — directory on host containing extension.crx
EXTENSION_ID=
EXTENSION_VERSION=1.0.0
EXTENSION_DIR=/home/nubes/extension

# Anthropic API (Vision pipeline)
ANTHROPIC_API_KEY=sk-ant-...

# Vision pipeline
VISION_BATCH_SIZE=20

# Cloud bootstrap (Hetzner/Cloudflare) — URL where agents download bootstrap profile
CLOUD_BOOTSTRAP_URL=https://
CLOUD_BOOTSTRAP_API_KEY=

# Human-readable server name (derived from customer domain, e.g. acme)
SERVER_NAME=

# SSL verification for outbound HTTP (to cloud). Set false only when cloud uses self-signed cert.
SSL_VERIFY=true

# Pinned image version — set automatically by CI deploy, or "latest"
SERVER_VERSION=latest

# Session secret for web cabinet — generate with: openssl rand -hex 32
SESSION_SECRET=
