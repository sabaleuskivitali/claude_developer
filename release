#!/bin/bash
set -e

COMPONENT=${1:?Usage: ./release <agent|server|cloud> ["commit message"|stable]}
ARG2=${2:-""}
ARG3=${3:-""}

# Определяем флаг stable и сообщение коммита
STABLE=false
MSG=""
for arg in "$ARG2" "$ARG3"; do
  if [ "$arg" = "stable" ]; then
    STABLE=true
  elif [ -n "$arg" ]; then
    MSG="$arg"
  fi
done

BRANCH="work/$COMPONENT"

WORKTREES=(
  ["agent"]="$HOME/Applications/seamlean-agent"
  ["server"]="$HOME/Applications/seamlean-server"
  ["cloud"]="$HOME/Applications/seamlean-cloud"
)
WORKTREE="${WORKTREES[$COMPONENT]}"

if [ -z "$WORKTREE" ]; then
  echo "❌ Неизвестный компонент: $COMPONENT (agent | server | cloud)"
  exit 1
fi

# --- Определяем версию по последнему обычному тегу (без -stable) ---
LAST_TAG=$(git tag -l "$COMPONENT/v*" | grep -v '\-stable' | sort -V | tail -1)

if [ -z "$LAST_TAG" ]; then
  VERSION="0.1.0"
  echo "ℹ️  Тегов нет, начинаем с v$VERSION"
else
  LAST_VERSION="${LAST_TAG#$COMPONENT/v}"
  IFS='.' read -r MAJOR MINOR PATCH <<< "$LAST_VERSION"
  PATCH=$((PATCH + 1))
  VERSION="$MAJOR.$MINOR.$PATCH"
  echo "📦 $LAST_TAG → v$VERSION"
fi

TAG="$COMPONENT/v$VERSION"
STABLE_TAG="$COMPONENT/v$VERSION-stable"

# --- Пишем VERSION в worktree ---
echo "$VERSION" > "$WORKTREE/$COMPONENT/VERSION"

# --- Коммит в worktree ---
cd "$WORKTREE"
if ! git diff --quiet || ! git diff --cached --quiet; then
  COMMIT_MSG="${MSG:-"$COMPONENT: v$VERSION"}"
  echo "📝 Коммит в $BRANCH: \"$COMMIT_MSG\""
  git add -A
  git commit -m "$COMMIT_MSG"
else
  echo "✅ Нечего коммитить в $BRANCH"
fi

# --- Merge → push → tag ---
cd "$HOME/Applications/Claude/Dev"

echo "🔀 Merging $BRANCH → main..."
git merge "$BRANCH" --no-edit

echo "⬆️  Pushing main..."
git push origin main

echo "🏷️  Tagging $TAG..."
git tag "$TAG"
git push origin "$TAG"

# --- Stable тег (если запрошен) ---
if [ "$STABLE" = true ]; then
  echo "🔒 Tagging $STABLE_TAG..."
  git tag "$STABLE_TAG"
  git push origin "$STABLE_TAG"
  echo ""
  echo "✅ $STABLE_TAG — GitHub Release создан, OTA уведомит агентов"
else
  echo ""
  echo "✅ $TAG — CI собирает артефакт"
  echo "   Для публичного релиза: ./release $COMPONENT stable"
fi
