#!/bin/bash
set -e

COMPONENT=${1:?Usage: ./release <agent|server|cloud> ["commit message"|stable]}

# Parse args
STABLE=false
MSG=""
for arg in "${@:2}"; do
  if   [ "$arg" = "stable" ]; then STABLE=true
  elif [ -n "$arg" ];         then MSG="$arg"
  fi
done

declare -A WORKTREES=(
  ["agent"]="$HOME/Applications/seamlean-agent"
  ["server"]="$HOME/Applications/seamlean-server"
  ["cloud"]="$HOME/Applications/seamlean-cloud"
)
WORKTREE="${WORKTREES[$COMPONENT]}"

if [ -z "$WORKTREE" ]; then
  echo "❌ Неизвестный компонент: $COMPONENT (agent | server | cloud)"
  exit 1
fi

BRANCH="work/$COMPONENT"
DEV_DIR="$HOME/Applications/Claude/Dev"

# --- Проверяем что worktree на правильной ветке ---
WORKTREE_BRANCH=$(git -C "$WORKTREE" branch --show-current 2>/dev/null || echo "")
if [ "$WORKTREE_BRANCH" != "$BRANCH" ]; then
  echo "❌ Worktree $WORKTREE на ветке '$WORKTREE_BRANCH', ожидается '$BRANCH'"
  exit 1
fi

# --- Версия по последнему тегу ---
cd "$DEV_DIR"
LAST_TAG=$(git tag -l "$COMPONENT/v*" | grep -v '\-stable' | sort -V | tail -1)
if [ -z "$LAST_TAG" ]; then
  VERSION="0.1.0"
else
  LAST_VERSION="${LAST_TAG#$COMPONENT/v}"
  IFS='.' read -r MAJOR MINOR PATCH <<< "$LAST_VERSION"
  PATCH=$((PATCH + 1))
  VERSION="$MAJOR.$MINOR.$PATCH"
fi
TAG="$COMPONENT/v$VERSION"
echo "📦 ${LAST_TAG:-(нет тегов)} → $TAG"

# --- Пишем VERSION и коммитим в worktree ---
# VERSION всегда меняется → тег всегда на свежем компонентном коммите, не на чужом
echo "$VERSION" > "$WORKTREE/$COMPONENT/VERSION"

cd "$WORKTREE"
git add -A
COMMIT_MSG="${MSG:-"release: $COMPONENT v$VERSION"}"
echo "📝 Коммит в $BRANCH: \"$COMMIT_MSG\""
git commit -m "$COMMIT_MSG

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>"

# --- Merge → main → push → tag ---
cd "$DEV_DIR"
echo "🔀 Merging $BRANCH → main..."
git merge "$BRANCH" --no-edit

echo "⬆️  Pushing main..."
git push origin main

echo "🏷️  Tagging $TAG..."
git tag "$TAG"
git push origin "$TAG"

# --- Stable ---
if [ "$STABLE" = true ]; then
  STABLE_TAG="$COMPONENT/v$VERSION-stable"
  echo "🔒 Tagging $STABLE_TAG..."
  git tag "$STABLE_TAG"
  git push origin "$STABLE_TAG"

  # Читаем stable-версии других компонентов из git-тегов
  _stable_ver() {
    local c=$1
    [ "$c" = "$COMPONENT" ] && { echo "$VERSION"; return; }
    local t
    t=$(git tag -l "$c/v*-stable" | sort -V | tail -1)
    [ -n "$t" ] && echo "${t#$c/v}" | sed 's/-stable//' || echo "unknown"
  }

  AGENT_VER=$(_stable_ver agent)
  SERVER_VER=$(_stable_ver server)
  CLOUD_VER=$(_stable_ver cloud)
  TODAY=$(date +%Y-%m-%d)

  # Обновляем COMPATIBILITY.json
  cat > "$DEV_DIR/COMPATIBILITY.json" <<JSON
{
  "cloud":   "$CLOUD_VER",
  "server":  "$SERVER_VER",
  "agent":   "$AGENT_VER",
  "updated": "$TODAY"
}
JSON
  git add COMPATIBILITY.json
  git commit -m "chore: COMPATIBILITY.json — $COMPONENT $VERSION stable

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>"
  git push origin main

  # system/vDATE — защита от коллизий
  SYS_BASE="system/v$(date +%Y.%m.%d)"
  SYS_TAG="$SYS_BASE"
  for suffix in "" ".2" ".3" ".4" ".5"; do
    SYS_TAG="${SYS_BASE}${suffix}"
    git tag "$SYS_TAG" 2>/dev/null && break
  done
  git push origin "$SYS_TAG"

  echo ""
  echo "✅ $STABLE_TAG + $SYS_TAG"
  echo "   cloud=$CLOUD_VER  server=$SERVER_VER  agent=$AGENT_VER"
else
  echo ""
  echo "✅ $TAG — CI собирает артефакт"
  echo "   Для стабильного релиза: ./release $COMPONENT stable"
fi
